# ===== NutriFit environment variables =====
# Copy this file to `.env` for local dev, and set the same keys in your
# Vercel project settings (Project → Settings → Environment Variables).

# --- Database ---
# LOCAL DEV (SQLite): a file path
DATABASE_URL="file:./dev.db"
#
# VERCEL / PRODUCTION (PostgreSQL): use your hosted Postgres connection string.
# Free options: Vercel Postgres, Neon (neon.tech), Supabase.
#   Vercel Postgres:  postgresql://user:pass@host/db?sslmode=require
#   Neon:              postgresql://user:pass@ep-xxx.neon.tech/db?sslmode=require
#
# When you switch to Postgres, also edit prisma/schema.prisma:
#   datasource db { provider = "postgresql" ... }   (was "sqlite")
# Then run: bun run db:push   (creates the tables in Postgres)

# --- Auth ---
# Any long random string. Generate one with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-secret"

# --- AI (Gemini) ---
# Get a free key at https://aistudio.google.com/app/apikey
# Used by the AI Copilot, Meal Analyzer, and Workout Generator.
# If unset, the app falls back to the sandbox AI SDK (dev only).
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
