# ===== NutriFit environment variables =====
# Copy this file to `.env` for local dev, and set the same keys in your
# Vercel project settings (Project → Settings → Environment Variables).
#
# The Prisma datasource provider is selected by DATABASE_PROVIDER:
#   - sqlite     → local dev (file-based, no server needed)
#   - postgresql → production (hosted Postgres on Vercel/Neon/Supabase)

# --- Database provider ---
# Local dev:   sqlite
# Vercel prod: postgresql
DATABASE_PROVIDER="sqlite"

# --- Database URL ---
# Local dev (sqlite): a file path
DATABASE_URL="file:./dev.db"
#
# Vercel production (postgresql): your hosted Postgres connection string.
# Free options: Vercel Postgres, Neon (neon.tech), Supabase.
#   postgresql://user:pass@host/db?sslmode=require
#
# When you switch to Postgres on Vercel, set:
#   DATABASE_PROVIDER=postgresql
#   DATABASE_URL=postgresql://...
# Then run `bun run db:push` against that DB to create the tables.

# --- Auth ---
# Any long random string. Generate one with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-secret"

# --- AI (Gemini) ---
# Get a free key at https://aistudio.google.com/app/apikey
# Used by the AI Copilot, Meal Analyzer, and Workout Generator.
# If unset, the app falls back to the sandbox AI SDK (dev only).
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
