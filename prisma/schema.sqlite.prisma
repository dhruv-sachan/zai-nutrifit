// Prisma schema for NutriFit — AI-powered health & nutrition platform
// Docs: https://pris.ly/d/prisma-schema
//
// NOTE: This is the SQLite schema used for local dev in this sandbox.
// For Vercel production (PostgreSQL), use prisma/schema.postgres.prisma —
// run `bun run db:use-postgres` to swap it in, or set it up at deploy time.
// The `db:provider` script auto-selects the right schema based on
// DATABASE_PROVIDER env var.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A registered user of NutriFit.
model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  /// bcrypt-hashed password.
  password      String
  /// Flips to true after the biometric onboarding flow is completed.
  onboardingDone Boolean   @default(false)
  /// Nested profile object: { age, sex, heightCm, weightKg, stepGoal,
  /// exerciseType, dietPreference, targetCalories, macros:{protein,carbs,fat} }
  profile       Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  dailyLogs     DailyLog[]
}

/// A single day's tracked metrics for a user (keyed by userId + date).
model DailyLog {
  id        String @id @default(cuid())
  userId    String
  /// YYYY-MM-DD (string keeps SQLite lookups simple & timezone-safe).
  date      String
  calories  Float  @default(0)
  protein   Float  @default(0)
  carbs     Float  @default(0)
  fat       Float  @default(0)
  steps     Int    @default(0)
  water     Float  @default(0)
  sleep     Float  @default(0)
  /// AI-generated workout exercises logged for this day (JSON array).
  exercises Json?

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}
